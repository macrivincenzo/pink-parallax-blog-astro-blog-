---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost = posts.find(post => post.slug === 'business-valuation-firms-insiders-guide');
const otherPosts = posts.filter(post => post.slug !== 'business-valuation-firms-insiders-guide');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description="In-depth articles, guides, and insights on business valuation, market trends, and maximizing your company's worth." />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			.featured-post {
				grid-column: 1 / -1;
				margin-bottom: 2rem;
				border: 1px solid #e0e0e0;
				padding: 2rem;
				border-radius: 8px;
				background-color: #f9f9f9;
			}
			.featured-post a {
				text-decoration: none;
				color: inherit;
			}
			.featured-post .title {
				font-size: 2.5em;
				margin-bottom: 0.5em;
				color: #2c3e50;
			}
			.featured-post .description {
				font-size: 1.2em;
				color: #34495e;
			}
			.post-list {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 2rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<h1>The Valuation Genie Blog</h1>
			<p>In-depth articles, guides, and insights on business valuation, market trends, and maximizing your company's worth.</p>
			
			{featuredPost && (
				<section class="featured-post">
					<a href={`/blog/${featuredPost.slug}/`}>
						<h2 class="title">{featuredPost.data.title}</h2>
						<p class="description">{featuredPost.data.description}</p>
					</a>
				</section>
			)}

			<section class="post-list">
				{otherPosts.map((post) => (
					<article>
						<a href={`/blog/${post.slug}/`}>
							<h3 class="title">{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
